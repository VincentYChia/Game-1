{
  "description": "Model backend configuration for AI-powered systems. Controls which LLM backend is used for each task type, with fallback chains for resilience.",

  "backends": {
    "ollama": {
      "enabled": true,
      "base_url": "http://localhost:11434",
      "default_model": "llama3.1:8b",
      "timeout_seconds": 30.0,
      "description": "Local Ollama server for offline LLM inference"
    },
    "claude": {
      "enabled": true,
      "model": "claude-sonnet-4-20250514",
      "max_tokens": 2000,
      "temperature": 0.4,
      "top_p": 0.95,
      "timeout_seconds": 30.0,
      "description": "Anthropic Claude API for high-quality inference"
    },
    "mock": {
      "enabled": true,
      "description": "Deterministic template-based responses for testing and fallback"
    }
  },

  "task_routing": {
    "crafting": {
      "primary": "claude",
      "description": "Item generation from crafting — uses existing llm_item_generator flow"
    },
    "dialogue": {
      "primary": "ollama",
      "description": "NPC dialogue generation"
    },
    "faction_dialogue": {
      "primary": "claude",
      "description": "NPC dialogue enhanced with faction affinity context"
    },
    "quests": {
      "primary": "ollama",
      "description": "Quest narrative generation"
    },
    "lore": {
      "primary": "ollama",
      "description": "Flavor text and world lore"
    },
    "faction_narrative": {
      "primary": "ollama",
      "description": "Faction reputation milestone narratives"
    },
    "wms_layer2": {
      "primary": "claude",
      "description": "WMS Layer 2: one-sentence factual narrations from evaluator triggers"
    },
    "wms_layer3": {
      "primary": "claude",
      "description": "WMS Layer 3: cross-domain consolidation across districts"
    },
    "wms_layer4": {
      "primary": "claude",
      "description": "WMS Layer 4: provincial summaries"
    },
    "wms_layer5": {
      "primary": "claude",
      "description": "WMS Layer 5: region-level summaries"
    },
    "wms_layer6": {
      "primary": "claude",
      "description": "WMS Layer 6: nation-level summaries"
    },
    "wms_layer7": {
      "primary": "claude",
      "description": "WMS Layer 7: world narrative threads"
    },
    "wns_layer2": {
      "primary": "ollama",
      "fallback": "mock",
      "description": "WNS NL2 locality weaver (placeholder — see PLACEHOLDER_LEDGER.md §12)"
    },
    "wns_layer3": {
      "primary": "ollama",
      "fallback": "mock",
      "description": "WNS NL3 district weaver (placeholder)"
    },
    "wns_layer4": {
      "primary": "ollama",
      "fallback": "mock",
      "description": "WNS NL4 region weaver (placeholder)"
    },
    "wns_layer5": {
      "primary": "ollama",
      "fallback": "mock",
      "description": "WNS NL5 nation weaver (placeholder)"
    },
    "wns_layer6": {
      "primary": "ollama",
      "fallback": "mock",
      "description": "WNS NL6 nation-to-world seam weaver (placeholder)"
    },
    "wns_layer7": {
      "primary": "ollama",
      "fallback": "mock",
      "description": "WNS NL7 world embroiderer (placeholder)"
    },
    "wes_execution_planner": {
      "primary": "claude",
      "fallback": "ollama",
      "description": "WES Tier 1 planner — cloud tolerated (§5.2); Ollama local on escalation (placeholder — see PLACEHOLDER_LEDGER.md §12)"
    },
    "wes_hub_hostiles": {
      "primary": "ollama",
      "fallback": "mock",
      "description": "WES Tier 2 hub — hostiles dispatcher (placeholder)"
    },
    "wes_hub_materials": {
      "primary": "ollama",
      "fallback": "mock",
      "description": "WES Tier 2 hub — materials dispatcher (placeholder)"
    },
    "wes_hub_nodes": {
      "primary": "ollama",
      "fallback": "mock",
      "description": "WES Tier 2 hub — resource nodes dispatcher (placeholder)"
    },
    "wes_hub_skills": {
      "primary": "ollama",
      "fallback": "mock",
      "description": "WES Tier 2 hub — skills dispatcher (no tag invention) (placeholder)"
    },
    "wes_hub_titles": {
      "primary": "ollama",
      "fallback": "mock",
      "description": "WES Tier 2 hub — titles dispatcher (placeholder)"
    },
    "wes_tool_hostiles": {
      "primary": "ollama",
      "fallback": "mock",
      "description": "WES Tier 3 executor_tool — hostile JSON generator (placeholder)"
    },
    "wes_tool_materials": {
      "primary": "ollama",
      "fallback": "mock",
      "description": "WES Tier 3 executor_tool — material JSON generator (placeholder)"
    },
    "wes_tool_nodes": {
      "primary": "ollama",
      "fallback": "mock",
      "description": "WES Tier 3 executor_tool — resource-node JSON generator (placeholder)"
    },
    "wes_tool_skills": {
      "primary": "ollama",
      "fallback": "mock",
      "description": "WES Tier 3 executor_tool — skill JSON generator (placeholder)"
    },
    "wes_tool_titles": {
      "primary": "ollama",
      "fallback": "mock",
      "description": "WES Tier 3 executor_tool — title JSON generator (placeholder)"
    },
    "wes_supervisor": {
      "primary": "ollama",
      "fallback": "mock",
      "description": "WES cross-tier common-sense reviewer (CC1, §5.6) (placeholder)"
    }
  },

  "fallback_chain": ["ollama", "claude", "mock"],

  "rate_limits": {
    "ollama": {
      "max_concurrent": 2,
      "cooldown_ms": 100,
      "description": "Local model — higher concurrency, lower cooldown"
    },
    "claude": {
      "max_concurrent": 1,
      "cooldown_ms": 1000,
      "description": "API model — rate-limited, higher cooldown"
    },
    "mock": {
      "max_concurrent": 10,
      "cooldown_ms": 0,
      "description": "No limits on mock backend"
    }
  },

  "defaults": {
    "temperature": 0.4,
    "max_tokens": 2000,
    "response_format": "text"
  }
}
